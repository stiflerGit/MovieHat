# Server listen address
ADDR=0.0.0.0:8080

# SQLite database path
DB_PATH=./moviehat.db

# Required: secret used to hash session and invitation tokens
AUTH_SECRET=change-me

# Base frontend URL used to build invitation links.
# Returned links use this base URL with the invitation token in the fragment,
# for example: https://moviehat.app/invite#<token>
FRONTEND_INVITATION_URL=https://moviehat.app/invite

# Optional bootstrap for the first user.
# Keep disabled in normal runs. Enable only when seeding a fresh environment.
BOOTSTRAP_ENABLED=true
BOOTSTRAP_EMAIL=admin@moviehat.com
BOOTSTRAP_PASSWORD=change-me-password
